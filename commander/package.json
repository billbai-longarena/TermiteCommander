{
  "name": "termite-commander",
  "version": "0.1.3",
  "description": "Autonomous orchestration engine for the Termite Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "termite-commander": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "skills/",
    "plugins/"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/billbai-longarena/TermiteCommander.git",
    "directory": "commander"
  },
  "keywords": [
    "termite",
    "orchestration",
    "ai-agents",
    "colony",
    "multi-model"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
